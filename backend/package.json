{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:all": "concurrently \"tsx watch src/server.ts\" \"tsx watch src/worker.ts\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:all": "pm2 start dist/server.js --name 'api-server' && pm2 start dist/worker.js --name 'queue-worker'",
    "format": "prettier --write src/**/*.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "knex:dev": "tsx node_modules/knex/bin/cli.js --knexfile src/lib/knex/knexfile.ts",
    "knex:prod": "knex --knexfile dist/lib/knex/knexfile.js",
    "migrate:make": "npm run knex:dev -- migrate:make",
    "migrate:rollback": "npm run knex:dev -- migrate:rollback",
    "migrate:latest:dev": "npm run knex:dev -- migrate:latest",
    "migrate:latest": "npm run knex:prod -- migrate:latest",
    "script:create-partitions:dev": "tsx src/scripts/create-partitions.ts",
    "script:create-partitions": "node dist/scripts/create-partitions.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.10",
    "node-cron": "^4.2.1",
    "node-mailjet": "^6.0.11",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "tsyringe": "^4.10.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
